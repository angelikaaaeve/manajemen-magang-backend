S3_BUCKET=your-bucket-name
S3_ACCESS_KEY=your-s3-access-key
S3_SECRET_KEY=your-s3-secret-key
S3_REGION=auto
S3_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
S3_PUBLIC_URL=https://your-cdn-domain.example.com

DB_URL=jdbc:postgresql://localhost:5432/manajemen_magang
DB_USERNAME=postgres
DB_PASSWORD=your-db-password

# Secret key required in the register payload (role=mentor) to create a mentor account
MENTOR_SECRET_KEY=change-this-mentor-secret-key
ALLOWED_CORS=http://localhost:3000
SERVER_PORT=8080
