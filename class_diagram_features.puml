@startuml Manajemen_Magang_Class_Diagram

skinparam classAttributeIconSize 0
skinparam classFontSize 11
skinparam classFontStyle bold
skinparam classHeaderBackgroundColor #1a1f6e
skinparam classHeaderFontColor #ffffff
skinparam classBorderColor #2F578A
skinparam classBackgroundColor #F8FAFC
skinparam arrowColor #36ADA3
skinparam arrowThickness 1.5
skinparam packageBackgroundColor #EEF2FF
skinparam packageBorderColor #2F578A
skinparam packageFontColor #121358
skinparam packageFontStyle bold
skinparam noteBackgroundColor #FFFDE7
skinparam noteBorderColor #F59E0B
skinparam shadowing false
skinparam roundCorner 10
hide empty members

' ═══════════════════════════════════════════════════════════
'  PACKAGE: iam
' ═══════════════════════════════════════════════════════════
package "modules.iam" #EEF2FF {

    enum Role {
        admin
        mahasiswa
        mentor
        --
        + fromString(role: String) : Role
    }

    class UserEntity {
        - id : UUID
        - email : String
        - password : String
        - role : Role
        - isActive : boolean
        - createdAt : LocalDateTime
        - updatedAt : LocalDateTime
        --
        + getId() : UUID
        + getEmail() : String
        + getRole() : Role
        + isActive() : boolean
    }

    class MahasiswaEntity {
        - id : UUID
        - userId : UUID
        - nim : String
        - nama : String
        - noHp : String
        - gender : String
        - idUniversity : Long
        - universitas : String <<transient>>
        --
        + getId() : UUID
        + getUserId() : UUID
        + getNim() : String
        + getNama() : String
        + getGender() : String
        + getIdUniversity() : Long
    }

    class MentorEntity {
        - id : UUID
        - userId : UUID
        - nama : String
        --
        + getId() : UUID
        + getUserId() : UUID
        + getNama() : String
    }

    class LoginRequest <<record>> {
        + email : String
        + password : String
    }

    class RegisterRequest <<record>> {
        + email : String
        + password : String
        + role : String
        + nim : String
        + nama : String
        + noHp : String
        + gender : String
        + universitas : String
        + secretKey : String
    }

    class UpdateUserRequest <<record>> {
        + nama : String
        + noHp : String
    }

    class LoginResponse <<record>> {
        + accessToken : String
    }

    class UserResponse <<record>> {
        + id : UUID
        + email : String
        + role : String
        + nim : String
        + nama : String
        + noHp : String
        + gender : String
        + universitas : String
    }

    interface IamService <<interface>> {
        + register(req: RegisterRequest, clientIp: String) : UserResponse
        + login(req: LoginRequest) : LoginResponse
        + getMe(userId: UUID) : UserResponse
        + update(userId: UUID, req: UpdateUserRequest) : UserResponse
    }

    class IamController {
        - iamService : IamService
        --
        + register(req: RegisterRequest, request: HttpServletRequest) : ResponseEntity<UserResponse>
        + login(req: LoginRequest, response: HttpServletResponse) : ResponseEntity<LoginResponse>
        + logout(response: HttpServletResponse) : ResponseEntity<Void>
        + me() : ResponseEntity<UserResponse>
        + update(req: UpdateUserRequest) : ResponseEntity<UserResponse>
    }

    UserEntity --> Role
    IamController --> IamService
    IamService ..> LoginRequest : uses
    IamService ..> RegisterRequest : uses
    IamService ..> UpdateUserRequest : uses
    IamService ..> LoginResponse : returns
    IamService ..> UserResponse : returns
    UserEntity "1" --> "0..1" MahasiswaEntity : memiliki
    UserEntity "1" --> "0..1" MentorEntity    : memiliki
}

' ═══════════════════════════════════════════════════════════
'  PACKAGE: universitas
' ═══════════════════════════════════════════════════════════
package "modules.universitas" #EEF2FF {

    class UniversitasRequest <<record>> {
        + nameUniversity : String
    }

    class UniversitasResponse <<record>> {
        + id : Long
        + nameUniversity : String
        + createdAt : LocalDateTime
    }

    interface UniversitasService <<interface>> {
        + addUniversitas(req: UniversitasRequest) : UniversitasResponse
        + editUniversitas(id: Long, req: UniversitasRequest) : UniversitasResponse
        + listUniversitas() : List<UniversitasResponse>
        + deleteUniversitas(id: Long) : void
    }

    UniversitasService ..> UniversitasRequest : uses
    UniversitasService ..> UniversitasResponse : returns
}

' ═══════════════════════════════════════════════════════════
'  PACKAGE: data_mahasiswa
' ═══════════════════════════════════════════════════════════
package "modules.data_mahasiswa" #EEF2FF {

    class StudentRequest <<record>> {
        + email : String
        + password : String
        + nim : String
        + nama : String
        + noHp : String
        + gender : String
        + idUniversity : Long
        + tanggalMulai : LocalDate
        + tanggalBerakhir : LocalDate
        + periodeStatus : String
    }

    class UpdateStudentRequest <<record>> {
        + nim : String
        + nama : String
        + noHp : String
        + gender : String
        + idUniversity : Long
    }

    class StudentResponse <<record>> {
        + id : UUID
        + userId : UUID
        + email : String
        + nim : String
        + nama : String
        + noHp : String
        + gender : String
        + idUniversity : Long
        + universitas : String
        + periodeId : UUID
        + tanggalMulai : LocalDate
        + tanggalBerakhir : LocalDate
        + statusPeriode : String
        + mentorId : UUID
        + namaMentor : String
    }

    class StudentStatResponse <<record>> {
        + totalMahasiswa : Long
        + totalAktif : Long
        + totalSelesai : Long
    }

    interface DataMahasiswaService <<interface>> {
        + addStudent(req: StudentRequest) : StudentResponse
        + editStudent(id: UUID, req: UpdateStudentRequest) : StudentResponse
        + listStudents(gender: String, universitas: String, status: String) : List<StudentResponse>
        + getStudentDetail(id: UUID) : StudentResponse
        + getStudentStatistics(gender: String, universitas: String) : StudentStatResponse
        + getSisaWaktuMagang(userId: UUID) : Long
    }

    DataMahasiswaService ..> StudentRequest : uses
    DataMahasiswaService ..> UpdateStudentRequest : uses
    DataMahasiswaService ..> StudentResponse : returns
    DataMahasiswaService ..> StudentStatResponse : returns
}

' ═══════════════════════════════════════════════════════════
